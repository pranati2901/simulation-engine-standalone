# ── GoalCert Simulation Engine — configuration ────────────────────────
# Copy to .env and fill in. All settings are optional for local dev.

# Shared-secret auth. When set, EVERY request (except GET /health) must carry
# this value in the X-API-Key header — set the SAME value in the hub's
# SCENARIO_API_KEY. Leave blank for open local dev.
SCENARIO_API_KEY=

# Where the other two platforms live (server-to-server):
#  * Agentic AI — NL scenario authoring is DELEGATED here (this engine never
#    calls an LLM itself; see services/agent_client.py).
#  * Digital Twin — reserved for twin-grounded scenarios (services/twin_client.py).
AGENTIC_AI_BASE_URL=http://localhost:8001
DIGITAL_TWIN_BASE_URL=http://localhost:8080

# Persistence: SQLite file by default; Postgres in production, e.g.
# GOALCERT_DATABASE_URL=postgresql+psycopg://user:pass@db-host:5432/goalcert
# GOALCERT_DATABASE_URL=sqlite:///./simulation_engine.db

# CORS origins as a JSON list — only needed if a browser calls this engine
# directly. The hub calls server-to-server, which needs no CORS.
# GOALCERT_CORS_ORIGINS=["https://hub.goalcert.io"]

# Optional: used ONLY by the legacy /studio and /jilla direct-Anthropic paths.
# The main authoring path (/scenarios/author) goes through the Agentic AI
# platform and needs no key here.
ANTHROPIC_API_KEY=
